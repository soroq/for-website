{
  "name": "soroq-hosted-surface",
  "private": true,
  "version": "0.2.0",
  "description": "React marketing site and authenticated operator proxy for Soroq.",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:vercel": "vercel dev",
    "check:content": "node scripts/check-content.mjs",
    "build:search": "node scripts/gen-search-index.mjs",
    "build": "node scripts/check-content.mjs && tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "deploy": "vercel --prod"
  },
  "dependencies": {
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.57.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase-admin": "^13.5.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.13"
  }
}
