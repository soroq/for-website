{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/quickstart.html", "destination": "/quickstart", "permanent": true },
    { "source": "/cli.html", "destination": "/cli", "permanent": true },
    { "source": "/control-plane.html", "destination": "/control-plane", "permanent": true },
    { "source": "/compatibility.html", "destination": "/compatibility", "permanent": true },
    { "source": "/operator.html", "destination": "/operator", "permanent": true },
    { "source": "/getting-started.html", "destination": "/getting-started", "permanent": true },
    { "source": "/android-quickstart.html", "destination": "/android-quickstart", "permanent": true },
    { "source": "/ios-quickstart.html", "destination": "/ios-quickstart", "permanent": true },
    { "source": "/troubleshooting.html", "destination": "/troubleshooting", "permanent": true },
    {
      "source": "/docs",
      "has": [{ "type": "host", "value": "soroq.dev" }],
      "destination": "https://docs.soroq.dev/",
      "permanent": true
    },
    {
      "source": "/docs/:path*",
      "has": [{ "type": "host", "value": "soroq.dev" }],
      "destination": "https://docs.soroq.dev/:path*",
      "permanent": true
    },
    {
      "source": "/quickstart",
      "has": [{ "type": "host", "value": "docs.soroq.dev" }],
      "destination": "https://soroq.dev/quickstart",
      "permanent": true
    },
    {
      "source": "/control-plane",
      "has": [{ "type": "host", "value": "docs.soroq.dev" }],
      "destination": "https://soroq.dev/control-plane",
      "permanent": true
    },
    {
      "source": "/compatibility",
      "has": [{ "type": "host", "value": "docs.soroq.dev" }],
      "destination": "https://soroq.dev/compatibility",
      "permanent": true
    },
    {
      "source": "/operator",
      "has": [{ "type": "host", "value": "docs.soroq.dev" }],
      "destination": "https://soroq.dev/operator",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/operator/healthz",
      "destination": "/api/operator/product-readiness?__op=healthz"
    },
    {
      "source": "/api/v1/(.*)",
      "destination": "/api/v1/[...path]?path=$1"
    },
    {
      "source": "/quickstart",
      "destination": "/quickstart.html"
    },
    {
      "source": "/cli/login",
      "destination": "/cli-login.html"
    },
    {
      "source": "/cli",
      "destination": "/cli.html"
    },
    {
      "source": "/getting-started",
      "destination": "/getting-started.html"
    },
    {
      "source": "/android-quickstart",
      "destination": "/android-quickstart.html"
    },
    {
      "source": "/ios-quickstart",
      "destination": "/ios-quickstart.html"
    },
    {
      "source": "/troubleshooting",
      "destination": "/troubleshooting.html"
    },
    {
      "source": "/control-plane",
      "destination": "/control-plane.html"
    },
    {
      "source": "/compatibility",
      "destination": "/compatibility.html"
    },
    {
      "source": "/operator",
      "destination": "/operator.html"
    }
  ]
}
